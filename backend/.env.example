# PostgreSQL — use the password from your PostgreSQL install (NOT "postgres" unless you set it).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Special chars in password must be URL-encoded (@ → %40, # → %23).
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/qr_inventory?schema=public"

JWT_SECRET="replace-with-strong-secret"
JWT_EXPIRES_IN="1d"
PORT=4000
ADMIN_NAME="System Admin"
ADMIN_EMAIL="admin@inventory.local"
ADMIN_PASSWORD="ChangeMe123!"

LLM_PROVIDER=ollama
LLM_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=llama3.1:8b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=500
LLM_TIMEOUT_MS=8000
