// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum StockMovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

enum StockAdjustmentReason {
  DAMAGE
  LOSS
  RECOUNT
  MANUAL
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  role         UserRole      @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  scans        ScanHistory[]
  activities   ActivityLog[]
  audits       AuditTrail[]
  stockMovements StockMovement[]
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items     Item[]
  itemLinks ItemCategory[]
}

model Item {
  id          String        @id @default(uuid())
  name        String
  sku         String        @unique
  quantity    Int
  reservedQty Int           @default(0)
  price       Decimal       @db.Decimal(10, 2)
  supplier    String
  location    String
  description String?
  qrValue     String        @unique
  barcodeValue String       @unique
  lowStockAt  Int           @default(5)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  scans       ScanHistory[]
  activities  ActivityLog[]
  audits      AuditTrail[]
  categories  ItemCategory[]
  tags        ItemTag[]
  variants    ItemVariant[]
  stockMovements StockMovement[]
}

model StockMovement {
  id               String               @id @default(uuid())
  itemId           String
  type             StockMovementType
  quantity         Int
  beforeQty        Int
  afterQty         Int
  note             String?
  reference        String?
  sourceWarehouse  String?
  destinationWarehouse String?
  adjustmentReason StockAdjustmentReason?
  createdAt        DateTime             @default(now())
  userId           String?
  item             Item                 @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user             User?                @relation(fields: [userId], references: [id])
}

model ItemCategory {
  itemId     String
  categoryId String
  createdAt  DateTime @default(now())
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([itemId, categoryId])
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items     ItemTag[]
}

model ItemTag {
  itemId     String
  tagId      String
  createdAt  DateTime @default(now())
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}

model ItemVariant {
  id          String   @id @default(uuid())
  itemId      String
  name        String?
  sku         String   @unique
  size        String?
  color       String?
  model       String?
  quantity    Int      @default(0)
  reservedQty Int      @default(0)
  price       Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model ScanHistory {
  id        String   @id @default(uuid())
  qrCode    String
  note      String?
  createdAt DateTime @default(now())
  itemId    String
  userId    String?
  item      Item     @relation(fields: [itemId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id          String   @id @default(uuid())
  action      String
  entityType  String
  entityId    String
  description String?
  createdAt   DateTime @default(now())
  userId      String?
  itemId      String?
  user        User?    @relation(fields: [userId], references: [id])
  item        Item?    @relation(fields: [itemId], references: [id])
}

model AuditTrail {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  oldData    Json?
  newData    Json?
  createdAt  DateTime @default(now())
  userId     String?
  itemId     String?
  user       User?    @relation(fields: [userId], references: [id])
  item       Item?    @relation(fields: [itemId], references: [id])
}
